# 이 파일을 복사해 homes-secrets.properties 로 만들고 실제 값을 채운다. (homes-secrets.properties 는 gitignore)
# application.yml 이 spring.config.import 로 읽어들인다.

# DB (KST 저장: serverTimezone=Asia/Seoul)
db.url=jdbc:mysql://localhost:3306/homes?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
db.username=homes
db.password=change-me

# JWT HS256 비밀키 (최소 32바이트 권장, 랜덤 문자열)
jwt.secret=change-this-to-a-long-random-secret-at-least-32-bytes
